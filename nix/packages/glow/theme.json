{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#c6d0f5",
    "margin": 2
  },
  "block_quote": {
    "color": "#e5c890",
    "italic": true,
    "indent": 2
  },
  "paragraph": {},
  "list": {
    "color": "#c6d0f5",
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#ca9ee6",
    "bold": true
  },
  "h1": {
    "prefix": "# "
  },
  "h2": {
    "prefix": "## "
  },
  "h3": {
    "prefix": "### "
  },
  "h4": {
    "prefix": "#### "
  },
  "h5": {
    "prefix": "##### "
  },
  "h6": {
    "prefix": "###### "
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "color": "#e5c890",
    "italic": true
  },
  "strong": {
    "color": "#ef9f76",
    "bold": true
  },
  "hr": {
    "color": "#626880",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". ",
    "color": "#81c8be"
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#81c8be",
    "underline": true
  },
  "link_text": {
    "color": "#f4b8e4"
  },
  "image": {
    "color": "#81c8be",
    "underline": true
  },
  "image_text": {
    "color": "#f4b8e4",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "color": "#a6d189"
  },
  "code_block": {
    "color": "#ef9f76",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#c6d0f5"
      },
      "error": {
        "color": "#c6d0f5",
        "background_color": "#e78284"
      },
      "comment": {
        "color": "#626880"
      },
      "comment_preproc": {
        "color": "#f4b8e4"
      },
      "keyword": {
        "color": "#ca9ee6"
      },
      "keyword_reserved": {
        "color": "#ca9ee6"
      },
      "keyword_namespace": {
        "color": "#ca9ee6"
      },
      "keyword_type": {
        "color": "#81c8be"
      },
      "operator": {
        "color": "#ca9ee6"
      },
      "punctuation": {
        "color": "#c6d0f5"
      },
      "name": {
        "color": "#81c8be"
      },
      "name_builtin": {
        "color": "#81c8be"
      },
      "name_tag": {
        "color": "#f4b8e4"
      },
      "name_attribute": {
        "color": "#a6d189"
      },
      "name_class": {
        "color": "#81c8be"
      },
      "name_constant": {
        "color": "#ca9ee6"
      },
      "name_decorator": {
        "color": "#a6d189"
      },
      "name_exception": {},
      "name_function": {
        "color": "#a6d189"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "#99d1db"
      },
      "literal_date": {},
      "literal_string": {
        "color": "#e5c890"
      },
      "literal_string_escape": {
        "color": "#f4b8e4"
      },
      "generic_deleted": {
        "color": "#e78284"
      },
      "generic_emph": {
        "color": "#e5c890",
        "italic": true
      },
      "generic_inserted": {
        "color": "#a6d189"
      },
      "generic_strong": {
        "color": "#ef9f76",
        "bold": true
      },
      "generic_subheading": {
        "color": "#ca9ee6"
      },
      "background": {
        "background_color": "#303446"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}